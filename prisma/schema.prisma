// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   // bcrypt hashed
  createdAt    DateTime @default(now())

  memberships      GroupMember[]
  expensesPaid     Expense[]         @relation("PaidBy")
  splits           ExpenseSplit[]
  settlementsPaid  Settlement[]      @relation("SettlementPayer")
  settlementsRcvd  Settlement[]      @relation("SettlementPayee")
  comments         ExpenseComment[]
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
}

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime? // NULL = still active. Set when member leaves group.

  group    Group     @relation(fields: [groupId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Expense {
  id                 String   @id @default(uuid())
  groupId            String
  paidById           String
  description        String
  amountCents        Int      // Amount in original currency, stored as integer cents
  currency           String   @default("INR")
  inrEquivalentCents Int      // Converted INR value used for all balance calculations
  fxRate             Float    @default(1.0) // FX rate used for conversion. 1.0 for INR expenses.
  expenseDate        DateTime // Normalised date of expense
  importRow          Int?     // CSV row number, for import traceability
  createdAt          DateTime @default(now())

  group    Group          @relation(fields: [groupId], references: [id])
  paidBy   User           @relation("PaidBy", fields: [paidById], references: [id])
  splits   ExpenseSplit[]
  comments ExpenseComment[]
}

model ExpenseSplit {
  id               String  @id @default(uuid())
  expenseId        String
  userId           String
  amountOwedCents  Int     // Final resolved amount in INR cents
  splitType        String  // EQUAL | EXACT | PERCENTAGE | SHARE
  splitValue       Float?  // The % or share count. Null for EQUAL/EXACT.

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id])
}

model Settlement {
  id             String   @id @default(uuid())
  payerId        String
  payeeId        String
  groupId        String?
  amountCents    Int
  settlementDate DateTime @default(now())
  createdAt      DateTime @default(now())

  payer  User   @relation("SettlementPayer", fields: [payerId], references: [id])
  payee  User   @relation("SettlementPayee", fields: [payeeId], references: [id])
  group  Group? @relation(fields: [groupId], references: [id])
}

model ExpenseComment {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  expense  Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id])
}

model ImportSession {
  id            String   @id @default(uuid())
  fileName      String
  importedAt    DateTime @default(now())
  totalRows     Int
  importedRows  Int
  skippedRows   Int
  anomalyReport Json     // Full structured anomaly report stored as JSONB
}
